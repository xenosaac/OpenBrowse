{
  "name": "@openbrowse/memory-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/MemoryStore.d.ts",
      "import": "./dist/MemoryStore.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite.d.ts",
      "import": "./dist/sqlite.js"
    }
  },
  "dependencies": {
    "@openbrowse/contracts": "workspace:*",
    "better-sqlite3": "12.6.2"
  },
  "scripts": {
    "build": "tsc --build",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
